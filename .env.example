# ─────────────────────────────────────────────────────────────────────────
# Zion Shop — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# ─────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ─────────────────────────────────────────
# DATABASE_URL: pooled connection (used by app at runtime)
# DIRECT_URL:   direct connection (used by Prisma migrations)
# Get both from: Supabase project → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Supabase Auth & Client ───────────────────────────────────────────────
# Get from: Supabase project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Cloudinary (product image storage + CDN) ─────────────────────────────
# Get from: Cloudinary → Dashboard → Account Details
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="zion_shop_products"

# ── bKash Payment Gateway ────────────────────────────────────────────────
# Apply at: bkash.com/business; sandbox creds available immediately for dev.
BKASH_BASE_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_APP_KEY=""
BKASH_APP_SECRET=""

# ── SSLCommerz Payment Gateway ───────────────────────────────────────────
# Sign up at: sslcommerz.com (sandbox is free).
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_IS_LIVE="false"

# ── Resend (transactional email) ─────────────────────────────────────────
# Get from: resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="orders@zionshop.com"

# ── Auth / App Config ────────────────────────────────────────────────────
# Used to sign session tokens. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional: analytics & monitoring (set up in Phase 7) ─────────────────
# NEXT_PUBLIC_GA_ID=""
# SENTRY_DSN=""
